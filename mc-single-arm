def default_data_root(app_root: Path) -> Path:
    configured = os.environ.get("MC_SINGLE_ARM_DATA_ROOT")
    return Path(configured).resolve() if configured else app_root


def ensure_runtime_layout(app_root: Path, data_root: Path) -> dict[str, Path]:
    paths: dict[str, Path] = {}
    shared_seed_dir = SHARE_INFILES if SHARE_INFILES.exists() else app_root / "infiles"
    same_root = app_root.resolve() == data_root.resolve()

    for name in DATA_DIR_NAMES:
        target = app_root / name if same_root else data_root / name
        target.mkdir(parents=True, exist_ok=True)
        paths[name] = target

        if same_root:
            continue

        link = app_root / name
        if link.is_symlink():
            expected = str(target)
            if os.readlink(link) != expected:
                link.unlink()
                link.symlink_to(target)
        elif not link.exists():
            link.symlink_to(target)

    infiles_dir = paths["infiles"]
    if shared_seed_dir.exists() and not any(infiles_dir.iterdir()):
        for source in sorted(shared_seed_dir.glob("*.inp")):
            destination = infiles_dir / source.name
            if not destination.exists():
                shutil.copy2(source, destination)

    return paths


def normalize_filename(name: str, suffix: str) -> str:
    cleaned = Path(name.strip()).name
    if not cleaned:
        raise ValueError("Filename is required.")
    stem = Path(cleaned).stem if cleaned.endswith(suffix) else cleaned
    safe = re.sub(r"[^A-Za-z0-9._-]+", "_", stem).strip("._-")
    if not safe:
        raise ValueError("Filename contains no usable characters.")
    return f"{safe}{suffix}"


def normalize_basename(name: str) -> str:
    return Path(normalize_filename(name, ".inp")).stem


def coerce_value(field: Field, value: Any) -> Any:
    if value in (None, ""):
        return field.default
    if field.kind in {"int", "enum", "flag"}:
        return int(float(value))
    return float(value)


def format_value(field: Field, value: Any) -> str:
    coerced = coerce_value(field, value)
    if field.kind in {"int", "enum", "flag"}:
        return str(int(coerced))
    return format(float(coerced), ".15g")


